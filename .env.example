# ═══════════════════════════════════════════════════════════════
# AI Interview & Placement Copilot — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── AI API Keys ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here   # Optional fallback

# ── AI Model Config ──────────────────────────────────────────
AI_PROVIDER=gemini                         # gemini | openai
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# ── Backend Config ────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DEBUG=True
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./placement_copilot.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,docx

# ── Cache ─────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=30

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Semantic ranking model (downloaded automatically on first run)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

